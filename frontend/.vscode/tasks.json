{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: spring-boot run",
      "type": "shell",
      "command": ".\\gradlew.bat bootRun",
      "options": {
        "cwd": "${workspaceFolder}/../backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "java",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Started DemoApplication"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers"
      }
    },
    {
      "label": "frontend: vite dev",
      "type": "shell",
      "command": "npm.cmd run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http://localhost:5173/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev-servers"
      }
    },
    {
      "label": "dev: run all",
      "dependsOn": [
        "backend: spring-boot run",
        "frontend: vite dev"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
